# Copy this file to `.env.local` and replace the placeholders (never commit `.env.local`).

# Supabase — Project Settings → API (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://xviazqsnjpuhwuujgfvp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=paste_anon_public_key_here
# Server-only — Project Settings → API → service_role (never expose to the client or NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=paste_service_role_key_here

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=paste_anthropic_api_key_here

# Google Places / Maps — https://console.cloud.google.com/google/maps-apis
# Enable on your GCP project: Places API (Autocomplete, Text Search, Place Details, Place Photos),
# Maps Static API (server proxy fallback), Maps Embed API (interactive map in modals /go),
# Geocoding API (address → map when lat/lng missing).
# Server-only Places/Static key (never expose in client code):
GOOGLE_PLACES_API_KEY=paste_google_places_api_key_here
# Browser key for embedded interactive maps (same GCP key is fine if Maps Embed API is enabled).
# Restrict by HTTP referrer to your domains + http://localhost:* for dev.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=paste_same_or_browser_restricted_key_here
# Site origin (with protocol) for server-side Google API requests when your API key uses HTTP referrer restrictions.
# Must match the dev URL you use (including port), e.g. http://127.0.0.1:9002 or http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://127.0.0.1:9002
